# NVIDIA NIM API Key (get free at https://build.nvidia.com)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxx

# NIM API Base URL
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Default NIM model for all requests
DEFAULT_MODEL=meta/llama-3.3-70b-instruct

# Optional: Map specific Claude models to NIM models (JSON)
# MODEL_MAP={"claude-opus-4-6":"deepseek-ai/deepseek-r1","claude-sonnet-4-6":"meta/llama-3.3-70b-instruct"}

# Server
HOST=0.0.0.0
PORT=8082

# Timeout (seconds) - NIM 응답 대기 시간. Reasoning 모델은 첫 토큰까지 오래 걸릴 수 있음
TIMEOUT=600
